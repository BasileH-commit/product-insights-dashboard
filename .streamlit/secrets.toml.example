# Streamlit Cloud Secrets Template
# Copy this to Streamlit Cloud dashboard > App settings > Secrets
# DO NOT commit the actual secrets.toml file!

# Zendesk
ZENDESK_SUBDOMAIN = "smily1"
ZENDESK_EMAIL = "your-email@smily.com"
ZENDESK_TOKEN = "your-zendesk-api-token"

# Modjo
MODJO_API_KEY = "your-modjo-api-key"

# Notion (optional, for weekly reports)
NOTION_TOKEN = "your-notion-token"
